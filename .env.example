# ─── Git (padrão da empresa — R-020) ─────────────────────────────
# Credential helper local lê GITHUB_USERNAME e GITHUB_TOKEN do .env.
# Gerar PAT: https://github.com/settings/tokens (escopo: repo)
GITHUB_USERNAME="sisdigiai"
GITHUB_TOKEN="ghp_SUBSTITUA_PELO_SEU_TOKEN"   # rotação: ____-__-__ (até +90d)

# ─── Supabase Management API PAT ─────────────────────────────────
# Token para gerenciar o projeto via API (executar SQL, listar tabelas,
# aplicar migrations). NÃO é o ANON_KEY. Gerar em:
# https://supabase.com/dashboard/account/tokens
SUPABASE_TOKEN="sbp_SUBSTITUA_PELO_SEU_TOKEN"   # rotação: ____-__-__ (até +90d)

