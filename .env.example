# ╔════════════════════════════════════════════════════════════════╗
# ║  DIGIAI — Variáveis de Ambiente                               ║
# ║  Copie para .env e preencha. Nunca commite valores reais.     ║
# ╚════════════════════════════════════════════════════════════════╝

# ─── Supabase do DIGIAI (projeto principal) ──────────────────────
# Ref: hswyopqvnolqpmprqvzh | Region: sa-east-1
# Dashboard: https://supabase.com/dashboard/project/hswyopqvnolqpmprqvzh
VITE_SUPABASE_URL="https://hswyopqvnolqpmprqvzh.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# ─── Supabase do Clearix (ecossistema multi-tenant — só leitura) ──
# Ref: mhgbuplnxtfgipbemchb
# Dashboard: https://supabase.com/dashboard/project/mhgbuplnxtfgipbemchb
# Uso: views públicas para read + RPCs rpc_iam_* para write (JWT super_admin)
VITE_CLEARIX_SUPABASE_URL="https://mhgbuplnxtfgipbemchb.supabase.co"
VITE_CLEARIX_SUPABASE_ANON_KEY="your-clearix-anon-key-here"

# ─── Git (padrão da empresa) ─────────────────────────────────────
# Credential helper local lê GITHUB_USERNAME e GITHUB_TOKEN do .env
# para autenticar git push sem popup.
#
# Configurar uma vez por clone:
#   git config --local --unset-all credential.helper
#   git config --local --add credential.helper ""
#   git config --local --add credential.helper "$(pwd)/scripts/git-credential-env.sh"
#
# Gerar PAT: https://github.com/settings/tokens (escopo: repo)
# Doc canônica: docs/digiai/docs/07-operacao/convencoes-tecnicas-ecossistema.md
GITHUB_USERNAME="sisdigiai"
GITHUB_TOKEN="ghp_SUBSTITUA_PELO_SEU_TOKEN"

# ─── Supabase Management API PAT ─────────────────────────────────
# Token para gerenciar projeto via API (execute SQL, list tables, etc.)
# NÃO É o mesmo que ANON_KEY (que é só para client).
# Gerar em: https://supabase.com/dashboard/account/tokens
SUPABASE_TOKEN="sbp_SUBSTITUA_PELO_SEU_TOKEN"
